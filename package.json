{
  "name": "homestead-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Remote MCP server (Cloudflare Worker) that writes homestead notes/log entries back to the fuhrysteve/homestead repo. Narrow write surface, GitHub-OAuth gated, GitHub-App commit identity.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "agents": "^0.14.4",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250510.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
